rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Tour cover photos — required for covers to show on other devices
    match /tour_covers/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Tour expense receipts
    match /tour_receipts/{tourId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Profile photos (also allowed under tour_covers as profile_{uid}_*.jpg
    // because that rule is already live in production)
    match /profile_photos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Legacy auth profile path
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
